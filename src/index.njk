---
homeTab: "nav__tab--current"
---

{% extends "base.njk" %}
{% block main %}
{% include "nav.njk" %}
<main class="home">
  <p>
    <b>Hey, Doug here.</b>
    I'm passionate about developing practices for effective cooperation, with a focus on post-consensus decision-making.</p>
  <img
    src="./assets/img/Smiling_Kirchheim.jpg"
    class="image--profilePic"
    alt="Me, smiling, facing you; there is long grass and trees in the background.">
  <div class="linkbar">
    <a class="linkbar__entry" href="mailto:doug@dougwebb.site">
      {% include "layout-icons/email.svg" %}
      <!-- svg code must be in doc for styling, including nicer than raw -->
      <span>Email</span>
    </a>
    <a class="linkbar__entry" href="https://mastodon.xyz/@douginamug">
      {% include "layout-icons/mastodon.svg" %}
      <span>Mastodon</span>
    </a>
    <a class="linkbar__entry" href="https://github.com/DougInAMug">
      {% include "layout-icons/github.svg" %}
      <span>Github</span>
    </a>
    <a class="linkbar__entry" href="https://matrix.to/#/@douginamug:matrix.org">
      {% include "layout-icons/matrix-org--mod.svg" %}
      <span>Matrix</span>
    </a>
    <a class="linkbar__entry" href="https://t.me/douginamug">
      {% include "layout-icons/telegram--mod.svg" %}
      <span>Telegram</span>
    </a>
  </div>
  <div class="linkbar">
    <a class="linkbar__entry" href="https://gitlab.com/DougInAMug/dougwebb.site">
      {% include "layout-icons/source.svg" %}
      <span>Source</span>
    </a>
    <a class="linkbar__entry" href="rss.xml">
      {% include "layout-icons/rss.svg" %}
      <span>RSS</span>
    </a>
    <a class="linkbar__entry" href="https://creativecommons.org/publicdomain/zero/1.0/">
      {% include "layout-icons/cc0--mod.svg" %}
      <span>CC0</span>
    </a>
  </div>
</main>
{% endblock %}